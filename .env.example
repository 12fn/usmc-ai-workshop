# Template for the chatbot's .env. You do NOT edit this by hand — `scripts/unlock_key.py`
# renders `.env` from this file, substituting the real workshop key for the placeholder.
# (opencode gets the key separately, via its own credential store — it does not read .env.)
OPENAI_API_KEY=sk-ant-REPLACE_ME
OPENAI_BASE_URL=https://api.anthropic.com/v1
OPENAI_MODEL=claude-opus-4-8
