# Copy to .env and paste the WORKSHOP key from the slide. Do NOT commit .env.
# Same key value is used twice: opencode (coding) reads ANTHROPIC_API_KEY; the
# chatbot reads OPENAI_API_KEY (it talks OpenAI-format to the same model).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-ant-REPLACE_ME
OPENAI_BASE_URL=https://api.anthropic.com/v1
OPENAI_MODEL=claude-opus-4-8
